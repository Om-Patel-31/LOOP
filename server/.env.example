PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/loop_app
NODE_ENV=development
APP_ORIGIN=http://localhost:5173
UPLOAD_DIR=uploads
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# storage provider: s3 | gcs | memory
STORAGE_PROVIDER=s3
STORAGE_BUCKET=loop-encrypted-media

# S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# GCS
GCS_PROJECT_ID=
GCS_KEY_FILE=
